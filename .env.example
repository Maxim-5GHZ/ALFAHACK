# Caddy
CADDY_HOST=localhost
# Оставьте пустым, если нет реального домена (будет plain HTTP).
# Если есть домен — укажите email для Let's Encrypt:
CADDY_TLS_EMAIL=

# Backend
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
DATABASE_URL=postgresql+asyncpg://alfastart:alfastart_secret@localhost:5432/alfastart

# Frontend
NEXT_PUBLIC_API_URL=

# GigaChat AI
GIGACHAT_API_KEY=your-gigachat-api-key
GIGACHAT_CREDENTIALS_PATH=

# Yandex Maps
YANDEX_MAPS_API_KEY=your-yandex-maps-api-key

# Auth
AUTH_SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL (для docker-compose)
POSTGRES_USER=alfastart
POSTGRES_PASSWORD=alfastart_secret
POSTGRES_DB=alfastart
